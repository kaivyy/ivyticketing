{
  "__comment": "ivyticketing War-Day dashboard (Phase 20 — Observability). Import into Grafana with a Prometheus datasource. Panels mirror the masterplan metrics: active queue users, queue release rate, checkout/payment success, API p95 latency, error rate, DB connection usage, racepack scan rate.",
  "title": "ivyticketing — War Day",
  "uid": "ivyticketing-war-day",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "5s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "tags": ["ivyticketing", "war-room", "phase20"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Error Rate (5xx)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_requests_total{status=~\"5..\"}[1m])) / clamp_min(sum(rate(http_requests_total[1m])), 1)"
        }
      ]
    },
    {
      "id": 2,
      "title": "API Latency p95",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))"
        }
      ]
    },
    {
      "id": 3,
      "title": "Antrean Aktif (Active Queue Users)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "blue" } } },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "refId": "A", "expr": "sum(queue_active_users)" }]
    },
    {
      "id": 4,
      "title": "DB Connections In Use",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "refId": "A", "expr": "sum(db_connections_in_use)", "legendFormat": "in use" },
        { "refId": "B", "expr": "sum(db_connections_idle)", "legendFormat": "idle" }
      ]
    },
    {
      "id": 5,
      "title": "Queue Release Rate (per menit)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "targets": [
        { "refId": "A", "expr": "sum(rate(queue_released_total[1m])) * 60", "legendFormat": "released/min" }
      ]
    },
    {
      "id": 6,
      "title": "Checkout & Payment Success Rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(checkout_succeeded_total[5m])) / clamp_min(sum(rate(checkout_succeeded_total[5m])) + sum(rate(checkout_failed_total[5m])), 1)",
          "legendFormat": "checkout"
        },
        {
          "refId": "B",
          "expr": "sum(rate(payment_succeeded_total[5m])) / clamp_min(sum(rate(payment_succeeded_total[5m])) + sum(rate(payment_failed_total[5m])), 1)",
          "legendFormat": "payment"
        }
      ]
    },
    {
      "id": 7,
      "title": "HTTP Request Rate by Status",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10, "stacking": { "mode": "normal" } } } },
      "targets": [
        { "refId": "A", "expr": "sum(rate(http_requests_total[1m])) by (status)", "legendFormat": "{{status}}" }
      ]
    },
    {
      "id": 8,
      "title": "Payment Outcomes (per menit)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "bars", "fillOpacity": 40 } } },
      "targets": [
        { "refId": "A", "expr": "sum(rate(payment_succeeded_total[1m])) * 60", "legendFormat": "sukses/min" },
        { "refId": "B", "expr": "sum(rate(payment_failed_total[1m])) * 60", "legendFormat": "gagal/min" }
      ]
    },
    {
      "id": 9,
      "title": "Gateway Webhook Delay p95",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 21 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.95, sum(rate(gateway_webhook_delay_seconds_bucket[5m])) by (le))", "legendFormat": "p95" }
      ]
    },
    {
      "id": 10,
      "title": "Racepack Scan Rate (per menit)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 21 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "targets": [
        { "refId": "A", "expr": "sum(rate(racepack_scans_total[1m])) * 60", "legendFormat": "scan/min" }
      ]
    }
  ]
}
