---
export const prerender = false;
import "../styles/global.css";

// Flagship race date used for the hero countdown. Change per season.
const RACE_DATE = "2026-08-30T05:00:00+07:00";
const raceDateLabel = new Date(RACE_DATE).toLocaleDateString("id-ID", {
  weekday: "long",
  day: "numeric",
  month: "long",
  year: "numeric",
});

const distances = [
  {
    tag: "42.2 KM",
    name: "Marathon",
    desc: "Jarak penuh untuk pelari yang mengejar personal best dan status finisher.",
    price: "Rp 650.000",
    accent: "from-orange-500 to-rose-500",
  },
  {
    tag: "21.1 KM",
    name: "Half Marathon",
    desc: "Tantangan sempurna antara kecepatan dan daya tahan.",
    price: "Rp 450.000",
    accent: "from-sky-400 to-indigo-500",
  },
  {
    tag: "10 KM",
    name: "Road Race",
    desc: "Cepat, ramai, dan penuh energi sepanjang rute kota.",
    price: "Rp 300.000",
    accent: "from-emerald-400 to-teal-500",
  },
  {
    tag: "5 KM",
    name: "Fun Run",
    desc: "Untuk keluarga, komunitas, dan pelari pemula. Semua bisa ikut.",
    price: "Rp 200.000",
    accent: "from-fuchsia-400 to-purple-500",
  },
];

const features = [
  {
    title: "Antrean Adil",
    body: "Sistem war ticket menahan lonjakan puluhan ribu pendaftar serentak tanpa server jatuh dan tanpa calo.",
    icon: "M13 10V3L4 14h7v7l9-11h-7z",
  },
  {
    title: "Tanpa Oversell",
    body: "Kuota dikunci di level database. Slot yang habis benar-benar habis — tidak ada dobel booking.",
    icon: "M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z",
  },
  {
    title: "E-Ticket QR Instan",
    body: "Tiket ber-QR aman langsung terbit setelah pembayaran terkonfirmasi. Scan sekali, anti-duplikat.",
    icon: "M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m0 0V8m0 4v4m0 0H4",
  },
  {
    title: "Sertifikat Digital",
    body: "Hasil waktu tempuh dan sertifikat finisher otomatis dibuat dan bisa diunduh peserta.",
    icon: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z",
  },
];
---

<!doctype html>
<html lang="id" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>ivyticketing — Platform Registrasi Lomba Lari</title>
    <meta
      name="description"
      content="Platform registrasi dan tiket event lari skala besar. Antrean adil, tanpa oversell, e-ticket QR instan, dan sertifikat digital."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Oswald:wght@500;600;700&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --ink: #0a0e1a;
        --accent: #ff5a3c;
      }
      body {
        font-family: "Inter", system-ui, sans-serif;
      }
      .display {
        font-family: "Oswald", system-ui, sans-serif;
        letter-spacing: 0.01em;
      }
      .hero-bg {
        background:
          radial-gradient(1200px 600px at 15% -10%, rgba(255, 90, 60, 0.35), transparent 60%),
          radial-gradient(900px 500px at 95% 10%, rgba(56, 120, 255, 0.28), transparent 55%),
          linear-gradient(160deg, #0a0e1a 0%, #0d1428 55%, #0a0e1a 100%);
      }
      .hero-grid {
        background-image:
          linear-gradient(rgba(255, 255, 255, 0.04) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255, 255, 255, 0.04) 1px, transparent 1px);
        background-size: 64px 64px;
        mask-image: radial-gradient(circle at 50% 40%, black, transparent 80%);
      }
      .ghost {
        -webkit-text-stroke: 1px rgba(255, 255, 255, 0.06);
        color: transparent;
      }
      @keyframes floaty {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-8px); }
      }
    </style>
  </head>
  <body class="bg-[var(--ink)] text-white antialiased">
    <!-- Nav -->
    <header
      id="nav"
      class="fixed inset-x-0 top-0 z-50 transition-all duration-300"
    >
      <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
        <a href="/" class="display text-2xl font-700 tracking-wide">
          ivy<span class="text-[var(--accent)]">ticketing</span>
        </a>
        <nav class="hidden items-center gap-8 text-sm font-medium text-slate-200 md:flex">
          <a href="#distances" class="transition-colors hover:text-white">Kategori</a>
          <a href="#why" class="transition-colors hover:text-white">Kenapa Kami</a>
          <a href="/events" class="transition-colors hover:text-white">Event</a>
          <a href="/status" class="transition-colors hover:text-white">Status</a>
        </nav>
        <div class="flex items-center gap-3">
          <a
            href="/login"
            class="hidden text-sm font-medium text-slate-200 transition-colors hover:text-white sm:block"
            >Masuk</a
          >
          <a
            href="/events"
            class="rounded-full bg-[var(--accent)] px-5 py-2.5 text-sm font-semibold text-white shadow-lg shadow-orange-500/20 transition-transform hover:scale-105"
            >Daftar Sekarang</a
          >
        </div>
      </div>
    </header>

    <!-- Hero -->
    <section class="hero-bg relative flex min-h-screen items-center overflow-hidden">
      <div class="hero-grid absolute inset-0"></div>
      <div
        class="ghost display pointer-events-none absolute -right-10 top-24 hidden select-none text-[18rem] font-700 leading-none lg:block"
      >
        26
      </div>

      <div class="relative mx-auto w-full max-w-7xl px-6 pt-28 pb-16">
        <div class="max-w-3xl">
          <div
            class="mb-6 inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-slate-200 backdrop-blur"
          >
            <span class="h-2 w-2 animate-pulse rounded-full bg-[var(--accent)]"></span>
            Pendaftaran Dibuka
          </div>

          <h1 class="display text-5xl font-700 uppercase leading-[0.95] sm:text-7xl lg:text-8xl">
            Lari Menuju
            <span
              class="block bg-gradient-to-r from-[var(--accent)] via-orange-400 to-amber-300 bg-clip-text text-transparent"
              >Garis Finish</span
            >
          </h1>

          <p class="mt-6 max-w-xl text-lg text-slate-300">
            Platform registrasi lomba lari skala besar. Ribuan peserta mendaftar
            serentak — antrean tetap adil, kuota tetap aman, tiket langsung di tangan.
          </p>

          <div class="mt-9 flex flex-wrap items-center gap-4">
            <a
              href="/events"
              class="group inline-flex items-center gap-2 rounded-full bg-[var(--accent)] px-8 py-4 text-base font-semibold shadow-xl shadow-orange-500/30 transition-transform hover:scale-105"
            >
              Daftar Sekarang
              <svg class="h-5 w-5 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
            </a>
            <a
              href="#distances"
              class="inline-flex items-center gap-2 rounded-full border border-white/20 px-8 py-4 text-base font-semibold text-white transition-colors hover:bg-white/10"
            >
              Lihat Kategori
            </a>
          </div>

          <!-- Countdown -->
          <div class="mt-14">
            <p class="mb-3 text-xs font-semibold uppercase tracking-widest text-slate-400">
              Hitung Mundur Race Day · {raceDateLabel}
            </p>
            <div id="countdown" class="flex gap-4">
              {["Hari", "Jam", "Menit", "Detik"].map((label) => (
                <div class="min-w-[76px] rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-center backdrop-blur">
                  <div
                    class="display cd-value text-4xl font-700 tabular-nums"
                    data-unit={label}
                  >
                    --
                  </div>
                  <div class="mt-1 text-[11px] font-semibold uppercase tracking-wider text-slate-400">
                    {label}
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>

      <!-- Stat strip -->
      <div class="absolute inset-x-0 bottom-0 border-t border-white/10 bg-black/20 backdrop-blur">
        <div class="mx-auto grid max-w-7xl grid-cols-2 divide-x divide-white/10 px-6 md:grid-cols-4">
          {[
            ["50K+", "Peserta terlayani"],
            ["0", "Insiden oversell"],
            ["4", "Kategori jarak"],
            ["99.9%", "Uptime saat war"],
          ].map(([stat, label]) => (
            <div class="py-5 text-center">
              <div class="display text-3xl font-700 text-[var(--accent)]">{stat}</div>
              <div class="mt-0.5 text-xs uppercase tracking-wider text-slate-400">{label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Distances -->
    <section id="distances" class="bg-slate-50 py-24 text-slate-900">
      <div class="mx-auto max-w-7xl px-6">
        <div class="mb-14 max-w-2xl">
          <p class="text-sm font-semibold uppercase tracking-widest text-[var(--accent)]">
            Pilih Tantanganmu
          </p>
          <h2 class="display mt-2 text-4xl font-700 uppercase sm:text-5xl">
            Kategori Lomba
          </h2>
          <p class="mt-3 text-slate-600">
            Dari fun run santai sampai marathon penuh. Setiap kategori punya kuota,
            harga, dan jadwal registrasi sendiri.
          </p>
        </div>

        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {distances.map((d) => (
            <div
              class="group relative overflow-hidden rounded-3xl border border-slate-200 bg-white p-7 shadow-sm transition-all hover:-translate-y-1 hover:shadow-xl"
            >
              <div
                class={`absolute -right-8 -top-8 h-28 w-28 rounded-full bg-gradient-to-br ${d.accent} opacity-20 blur-2xl transition-opacity group-hover:opacity-40`}
              ></div>
              <div
                class={`display inline-block rounded-lg bg-gradient-to-r ${d.accent} bg-clip-text text-4xl font-700 text-transparent`}
              >
                {d.tag}
              </div>
              <h3 class="display mt-2 text-2xl font-600 uppercase text-slate-900">
                {d.name}
              </h3>
              <p class="mt-3 min-h-[3.5rem] text-sm text-slate-600">{d.desc}</p>
              <div class="mt-6 flex items-center justify-between border-t border-slate-100 pt-5">
                <div>
                  <div class="text-[11px] uppercase tracking-wider text-slate-400">Mulai dari</div>
                  <div class="display text-xl font-700 text-slate-900">{d.price}</div>
                </div>
                <a
                  href="/events"
                  class="rounded-full bg-slate-900 px-4 py-2 text-xs font-semibold text-white transition-colors hover:bg-[var(--accent)]"
                  >Daftar</a
                >
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Why -->
    <section id="why" class="relative overflow-hidden bg-[var(--ink)] py-24">
      <div class="hero-grid absolute inset-0 opacity-40"></div>
      <div class="relative mx-auto max-w-7xl px-6">
        <div class="mb-14 max-w-2xl">
          <p class="text-sm font-semibold uppercase tracking-widest text-[var(--accent)]">
            Dibangun untuk skala
          </p>
          <h2 class="display mt-2 text-4xl font-700 uppercase text-white sm:text-5xl">
            Kenapa Lewat Kami
          </h2>
          <p class="mt-3 text-slate-400">
            Infrastruktur yang sama dipakai untuk event dengan puluhan ribu pendaftar
            serentak. Bukan sekadar form pendaftaran.
          </p>
        </div>

        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
          {features.map((f) => (
            <div class="rounded-3xl border border-white/10 bg-white/5 p-7 backdrop-blur transition-colors hover:bg-white/10">
              <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-[var(--accent)]/15">
                <svg class="h-6 w-6 text-[var(--accent)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                  <path stroke-linecap="round" stroke-linejoin="round" d={f.icon} />
                </svg>
              </div>
              <h3 class="display mt-5 text-xl font-600 uppercase text-white">{f.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-slate-400">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA band -->
    <section class="relative overflow-hidden bg-gradient-to-r from-[var(--accent)] via-orange-500 to-rose-500 py-20">
      <div class="mx-auto max-w-4xl px-6 text-center">
        <h2 class="display text-4xl font-700 uppercase text-white sm:text-6xl">
          Slot Terbatas.<br />Jangan Sampai Kehabisan.
        </h2>
        <p class="mx-auto mt-4 max-w-xl text-white/90">
          Registrasi dibuka untuk semua kategori. Amankan tempatmu di garis start
          sebelum kuota penuh.
        </p>
        <a
          href="/events"
          class="mt-8 inline-flex items-center gap-2 rounded-full bg-white px-9 py-4 text-base font-bold text-slate-900 shadow-xl transition-transform hover:scale-105"
        >
          Daftar Sekarang
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </a>
      </div>
    </section>

    <!-- Footer -->
    <footer class="bg-[var(--ink)] pt-16 pb-10 text-slate-400">
      <div class="mx-auto max-w-7xl px-6">
        <div class="grid gap-10 border-b border-white/10 pb-12 md:grid-cols-4">
          <div class="md:col-span-2">
            <div class="display text-2xl font-700 text-white">
              ivy<span class="text-[var(--accent)]">ticketing</span>
            </div>
            <p class="mt-3 max-w-sm text-sm">
              Platform registrasi dan tiket event lari skala besar. Antrean adil,
              tanpa oversell, e-ticket QR, dan sertifikat digital.
            </p>
          </div>
          <div>
            <h4 class="text-sm font-semibold uppercase tracking-wider text-white">Peserta</h4>
            <ul class="mt-4 space-y-2 text-sm">
              <li><a href="/events" class="transition-colors hover:text-white">Jelajahi Event</a></li>
              <li><a href="/login" class="transition-colors hover:text-white">Masuk / Daftar Akun</a></li>
              <li><a href="/status" class="transition-colors hover:text-white">Status Sistem</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-sm font-semibold uppercase tracking-wider text-white">Platform</h4>
            <ul class="mt-4 space-y-2 text-sm">
              <li><a href="/login" class="transition-colors hover:text-white">Organizer Console</a></li>
              <li><a href="#why" class="transition-colors hover:text-white">Fitur</a></li>
              <li><a href="#distances" class="transition-colors hover:text-white">Kategori</a></li>
            </ul>
          </div>
        </div>
        <div class="flex flex-col items-center justify-between gap-4 pt-8 text-xs sm:flex-row">
          <p>&copy; {new Date().getFullYear()} ivyticketing. Seluruh hak cipta dilindungi.</p>
          <p>Dibuat untuk event lari Indonesia.</p>
        </div>
      </div>
    </footer>

    <script is:inline define:vars={{ RACE_DATE }}>
      // Sticky nav background on scroll
      const nav = document.getElementById("nav");
      const onScroll = () => {
        if (window.scrollY > 24) {
          nav.classList.add("bg-[var(--ink)]/90", "backdrop-blur", "shadow-lg", "shadow-black/20");
        } else {
          nav.classList.remove("bg-[var(--ink)]/90", "backdrop-blur", "shadow-lg", "shadow-black/20");
        }
      };
      window.addEventListener("scroll", onScroll, { passive: true });
      onScroll();

      // Countdown
      const target = new Date(RACE_DATE).getTime();
      const cells = document.querySelectorAll("#countdown .cd-value");
      const pad = (n) => String(n).padStart(2, "0");
      function tick() {
        const diff = Math.max(0, target - Date.now());
        const s = Math.floor(diff / 1000);
        const days = Math.floor(s / 86400);
        const hours = Math.floor((s % 86400) / 3600);
        const mins = Math.floor((s % 3600) / 60);
        const secs = s % 60;
        const map = { Hari: days, Jam: pad(hours), Menit: pad(mins), Detik: pad(secs) };
        cells.forEach((el) => {
          const unit = el.getAttribute("data-unit");
          el.textContent = String(map[unit]);
        });
      }
      tick();
      setInterval(tick, 1000);
    </script>
  </body>
</html>
