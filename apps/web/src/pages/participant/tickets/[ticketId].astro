---
export const prerender = false;
import ParticipantLayout from "../../../layouts/ParticipantLayout.astro";
---
<ParticipantLayout title="Detail Tiket">
  <a href="/participant/tickets" class="text-sm text-slate-500">← Kembali</a>
  <div id="detail" class="mt-4"><p class="text-slate-500">Memuat…</p></div>

  <script>
    import { getTicket } from "../../../lib/tickets";
    import { esc } from "../../../lib/safe";
    import QRCode from "qrcode";

    const id = window.location.pathname.split("/").pop()!;
    const detail = document.getElementById("detail")!;
    try {
      const t = await getTicket(id);
      detail.innerHTML = `
        <div class="rounded-lg border border-slate-200 bg-white p-6 text-center">
          <h1 class="text-lg font-bold">${esc(t.eventTitle)}</h1>
          <p class="text-slate-600">${esc(t.categoryName)} · ${esc(t.ticketNumber)}</p>
          <p class="mt-1 text-sm ${t.status === "VALID" ? "text-green-600" : "text-slate-500"}">${esc(t.status)}</p>
          ${t.bibNumber ? `<p class="mt-3 inline-block rounded border border-slate-300 bg-slate-50 px-3 py-1.5 text-sm">BIB <span class="font-mono font-bold">${esc(t.bibNumber)}</span></p>` : ""}
          <canvas id="qr" class="mx-auto mt-4" width="220" height="220"></canvas>
          <p class="mt-4 text-sm text-slate-600">${esc(t.holderName)}</p>
        </div>`;
      await QRCode.toCanvas(document.getElementById("qr"), t.qrToken, { width: 220 });
    } catch (e) {
      const p = document.createElement("p");
      p.className = "text-red-600";
      p.textContent = (e as Error).message;
      detail.replaceChildren(p);
    }
  </script>
</ParticipantLayout>
