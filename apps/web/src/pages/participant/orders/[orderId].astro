---
export const prerender = false;
import ParticipantLayout from "../../../layouts/ParticipantLayout.astro";
---
<ParticipantLayout title="Detail Pesanan">
  <a href="/participant/orders" class="text-sm text-slate-500">← Kembali</a>
  <div id="detail" class="mt-4 space-y-6"><p class="text-slate-500">Memuat…</p></div>
  <script>
    import { getInvoice } from "../../../lib/invoice";
    import { getTicketByOrder } from "../../../lib/tickets";
    import { fetchOrder } from "../../../lib/checkout";
    import { esc } from "../../../lib/safe";
    const orderId = window.location.pathname.split("/").pop()!;
    const detail = document.getElementById("detail")!;
    const fmt = (n: number) => `Rp${n.toLocaleString("id-ID")}`;

    try {
      // Fetch order for status-based pay button
      const order = await fetchOrder(orderId);
      const canPay = order.status === "PENDING" || order.status === "AWAITING_PAYMENT";
      const isCancelledOrExpired = order.status === "CANCELLED" || order.status === "EXPIRED";
      const checkoutUrl = `/events/${order.eventId}/checkout?orderId=${order.id}`;

      let html = "";

      // Pay / status banner
      if (canPay) {
        html += `<div class="rounded-lg border border-amber-200 bg-amber-50 p-4 flex items-center justify-between">
          <div>
            <p class="font-semibold text-amber-800">Menunggu Pembayaran</p>
            <p class="text-sm text-amber-700">Total: ${fmt(order.total)}</p>
            ${order.expiredAt ? `<p class="text-xs text-amber-600 mt-1">Batas: ${new Date(order.expiredAt).toLocaleString("id-ID")}</p>` : ""}
          </div>
          <a href="${esc(checkoutUrl)}"
             class="rounded bg-slate-900 px-4 py-2 text-white text-sm hover:bg-slate-700 whitespace-nowrap">
            Bayar Sekarang
          </a>
        </div>`;
      } else if (isCancelledOrExpired) {
        html += `<div class="rounded-lg border border-slate-200 bg-slate-50 p-4">
          <p class="text-slate-600">Pesanan ini ${order.status === "CANCELLED" ? "dibatalkan" : "kedaluwarsa"}.</p>
        </div>`;
      }

      try {
        const inv = await getInvoice(orderId);
        html += `<div class="rounded-lg border border-slate-200 bg-white p-6">
          <div class="flex justify-between"><h2 class="font-bold">Invoice</h2><button onclick="window.print()" class="rounded border px-3 py-1 text-sm print:hidden">Cetak / PDF</button></div>
          <p class="text-sm text-slate-600">${esc(inv.orderNumber)} · ${esc(inv.status)}</p>
          <dl class="mt-3 space-y-1 text-sm">
            <div class="flex justify-between"><dt>Event</dt><dd>${esc(inv.eventTitle)}</dd></div>
            <div class="flex justify-between"><dt>Kategori</dt><dd>${esc(inv.categoryName)}</dd></div>
            <div class="flex justify-between font-semibold"><dt>Total</dt><dd>${fmt(inv.total)}</dd></div>
          </dl></div>`;
      } catch {
        html += `<p class="text-slate-500">Invoice tersedia setelah pembayaran lunas.</p>`;
      }
      try {
        const t = await getTicketByOrder(orderId);
        html += `<a href="/participant/tickets/${esc(t.id)}" class="block rounded-lg border border-slate-200 bg-white p-4 hover:border-slate-400">Lihat tiket: ${esc(t.ticketNumber)} (${esc(t.status)})</a>`;
      } catch { /* no ticket yet */ }
      detail.innerHTML = html;
    } catch (e) {
      const p = document.createElement("p");
      p.className = "text-red-600";
      p.textContent = (e as Error).message;
      detail.replaceChildren(p);
    }
  </script>
</ParticipantLayout>
