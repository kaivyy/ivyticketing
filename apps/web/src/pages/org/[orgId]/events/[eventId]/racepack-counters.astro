---
export const prerender = false;
import OrganizerLayout from "../../../../../layouts/OrganizerLayout.astro";
const { orgId, eventId } = Astro.params;
---
<OrganizerLayout title="Racepack Counter — ivyticketing">
  <div id="racepack-counters" data-org-id={orgId} data-event-id={eventId} class="space-y-6">
    <p class="text-slate-500">Memuat data counter…</p>
  </div>

  <script>
    import {
      listCounters,
      createCounter,
      updateCounter,
      setCounterActive,
      type Counter,
    } from "../../../../../lib/racepack";
    import { esc } from "../../../../../lib/safe";

    const root = document.getElementById("racepack-counters")!;
    const orgId = root.dataset.orgId!;
    const eventId = root.dataset.eventId!;

    function showMsg(id: string, text: string, isError = false) {
      const el = document.getElementById(id);
      if (!el) return;
      el.textContent = text;
      el.className = isError
        ? "mt-2 text-sm text-red-600"
        : "mt-2 text-sm text-green-700";
    }

    function statusBadge(active: boolean): string {
      const cls = active
        ? "bg-green-100 text-green-800"
        : "bg-slate-200 text-slate-700";
      const label = active ? "Aktif" : "Nonaktif";
      return `<span class="rounded px-2 py-0.5 text-xs font-medium ${cls}">${label}</span>`;
    }

    async function loadCounters() {
      const container = document.getElementById("counters-list");
      if (!container) return;
      try {
        const counters = await listCounters(orgId, eventId);
        if (!counters || counters.length === 0) {
          container.innerHTML = `<p class="text-sm text-slate-400">Belum ada counter pada event ini.</p>`;
          return;
        }
        container.innerHTML = counters
          .map(
            (c) => `
          <div class="rounded border border-slate-200 bg-slate-50 p-4 space-y-3" data-counter-id="${esc(c.id)}">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div>
                <p class="font-medium">${esc(c.name)}</p>
                <p class="text-xs text-slate-500">${c.location ? esc(c.location) : '<span class="italic text-slate-400">Lokasi belum diisi</span>'}</p>
              </div>
              <div class="flex items-center gap-3">
                ${statusBadge(c.active)}
                <button data-act="toggle" class="rounded border border-slate-300 bg-white px-3 py-1 text-xs text-slate-700 hover:bg-slate-100">
                  ${c.active ? "Nonaktifkan" : "Aktifkan"}
                </button>
              </div>
            </div>
            <div class="grid gap-2 md:grid-cols-3">
              <input data-field="name" type="text" value="${esc(c.name)}" placeholder="Nama counter"
                class="rounded border border-slate-300 px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
              <input data-field="location" type="text" value="${esc(c.location ?? "")}" placeholder="Lokasi (opsional)"
                class="rounded border border-slate-300 px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
              <button data-act="save" class="rounded bg-blue-600 px-3 py-1.5 text-sm text-white hover:bg-blue-700">Simpan</button>
            </div>
          </div>`
          )
          .join("");

        container.querySelectorAll<HTMLDivElement>("[data-counter-id]").forEach((row) => {
          const id = row.dataset.counterId!;
          const nameInput = row.querySelector<HTMLInputElement>('[data-field="name"]')!;
          const locInput = row.querySelector<HTMLInputElement>('[data-field="location"]')!;
          row.querySelector<HTMLButtonElement>('[data-act="save"]')?.addEventListener("click", async () => {
            try {
              const name = nameInput.value.trim();
              const location = locInput.value.trim();
              if (!name) {
                showMsg("counters-action-msg", "Nama counter wajib diisi.", true);
                return;
              }
              await updateCounter(orgId, eventId, id, {
                name,
                location: location || undefined,
              });
              showMsg("counters-action-msg", `Counter "${name}" diperbarui.`);
              await loadCounters();
            } catch (e) {
              showMsg("counters-action-msg", (e as Error).message, true);
            }
          });
          row.querySelector<HTMLButtonElement>('[data-act="toggle"]')?.addEventListener("click", async () => {
            const c = counters.find((x) => x.id === id);
            if (!c) return;
            try {
              await setCounterActive(orgId, eventId, id, !c.active);
              showMsg("counters-action-msg", `Counter "${c.name}" ${c.active ? "dinonaktifkan" : "diaktifkan"}.`);
              await loadCounters();
            } catch (e) {
              showMsg("counters-action-msg", (e as Error).message, true);
            }
          });
        });
      } catch (e) {
        container.replaceChildren(
          Object.assign(document.createElement("p"), {
            className: "text-sm text-red-600",
            textContent: (e as Error).message,
          })
        );
      }
    }

    root.innerHTML = `
      <h1 class="text-2xl font-bold text-slate-900">Racepack — Counter Manager</h1>

      <section class="rounded-lg border border-slate-200 bg-white p-6">
        <h2 class="mb-4 text-lg font-semibold">Tambah Counter</h2>
        <form id="create-counter-form" class="space-y-3 max-w-2xl">
          <div class="grid gap-3 md:grid-cols-2">
            <div>
              <label class="mb-1 block text-sm font-medium text-slate-700">Nama Counter</label>
              <input id="counter-name" type="text" placeholder="Counter A" required
                class="w-full rounded border border-slate-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
            </div>
            <div>
              <label class="mb-1 block text-sm font-medium text-slate-700">Lokasi (opsional)</label>
              <input id="counter-location" type="text" placeholder="Lobby Utama"
                class="w-full rounded border border-slate-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
            </div>
          </div>
          <button type="submit"
            class="rounded bg-green-600 px-4 py-2 text-sm font-medium text-white hover:bg-green-700">
            Tambah Counter
          </button>
        </form>
        <p id="create-counter-msg" class="mt-2 text-sm text-slate-500"></p>
      </section>

      <section class="rounded-lg border border-slate-200 bg-white p-6">
        <h2 class="mb-4 text-lg font-semibold">Daftar Counter</h2>
        <div id="counters-list" class="space-y-3">
          <p class="text-sm text-slate-400">Memuat…</p>
        </div>
        <p id="counters-action-msg" class="mt-2 text-sm text-slate-500"></p>
      </section>
    `;

    document.getElementById("create-counter-form")?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const name = (document.getElementById("counter-name") as HTMLInputElement).value.trim();
      const location = (document.getElementById("counter-location") as HTMLInputElement).value.trim();
      if (!name) {
        showMsg("create-counter-msg", "Nama counter wajib diisi.", true);
        return;
      }
      try {
        const c = await createCounter(orgId, eventId, name, location || undefined);
        showMsg("create-counter-msg", `Counter "${c.name}" berhasil dibuat.`);
        (document.getElementById("create-counter-form") as HTMLFormElement).reset();
        await loadCounters();
      } catch (err) {
        showMsg("create-counter-msg", (err as Error).message, true);
      }
    });

    loadCounters();
  </script>
</OrganizerLayout>