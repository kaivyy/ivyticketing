---
export const prerender = false;
import OrganizerLayout from "../../../../../layouts/OrganizerLayout.astro";
const { orgId, eventId } = Astro.params;
---
<OrganizerLayout title="Tiket & BIB — ivyticketing">
  <div id="tickets" data-org-id={orgId} data-event-id={eventId} class="rounded-lg border border-slate-200 bg-white p-6">
    <p class="text-slate-500">Memuat data tiket…</p>
  </div>

  <script>
    import { authedFetch } from "../../../../../lib/api";
    import { esc } from "../../../../../lib/safe";
    import {
      previewNextBib,
      assignNextBib,
      setBib,
      clearBib,
      bulkAssignBibs,
      bibsExportUrl,
    } from "../../../../../lib/bibs";

    interface Ticket {
      id: string;
      ticketNumber: string;
      status: string;
      holderName: string;
      holderEmail: string;
      categoryName: string;
      bibNumber?: string;
      bibAssignmentMethod?: "AUTO" | "MANUAL" | "OVERRIDE";
    }

    const root = document.getElementById("tickets")!;
    const orgId = root.dataset.orgId!;
    const eventId = root.dataset.eventId!;

    const apiBase = `/organizations/${orgId}/events/${eventId}/tickets`;

    async function loadTickets(): Promise<Ticket[]> {
      return authedFetch<Ticket[]>(apiBase);
    }

    function statusBadge(status: string): string {
      const color = status === "VALID" ? "bg-green-100 text-green-700"
        : status === "USED" ? "bg-slate-200 text-slate-700"
        : "bg-red-100 text-red-700";
      return `<span class="rounded px-2 py-0.5 text-xs ${color}">${esc(status)}</span>`;
    }

    function methodBadge(m?: string): string {
      if (!m) return "";
      const colors: Record<string, string> = {
        AUTO: "bg-blue-100 text-blue-700",
        MANUAL: "bg-amber-100 text-amber-700",
        OVERRIDE: "bg-purple-100 text-purple-700",
      };
      const c = colors[m] ?? "bg-slate-100 text-slate-700";
      return `<span class="ml-1 rounded px-1.5 py-0.5 text-[10px] ${c}">${esc(m)}</span>`;
    }

    async function refreshPreview() {
      const preview = document.getElementById("preview-next");
      if (!preview) return;
      try {
        const p = await previewNextBib(orgId, eventId);
        preview.innerHTML = `BIB berikutnya: <span class="font-mono font-bold">${esc(p.nextBib)}</span>`;
      } catch {
        preview.innerHTML = "";
      }
    }

    async function handleAutoAssign(ticketId: string) {
      try {
        await assignNextBib(orgId, eventId, ticketId);
        await render();
        await refreshPreview();
      } catch (e) {
        alert((e as Error).message);
      }
    }

    async function handleSet(ticketId: string) {
      const v = prompt("Masukkan nomor BIB baru (alphanumeric, max 32 chars):");
      if (!v) return;
      try {
        await setBib(orgId, eventId, ticketId, v.trim());
        await render();
      } catch (e) {
        alert((e as Error).message);
      }
    }

    async function handleClear(ticketId: string) {
      if (!confirm("Hapus BIB pada tiket ini?")) return;
      try {
        await clearBib(orgId, eventId, ticketId);
        await render();
        await refreshPreview();
      } catch (e) {
        alert((e as Error).message);
      }
    }

    async function handleBulkAssign() {
      if (!confirm("Assign BIB ke semua tiket VALID yang belum punya BIB?")) return;
      try {
        const res = await bulkAssignBibs(orgId, eventId);
        alert(`Assign: ${res.assigned} berhasil, ${res.failed} gagal${res.lastBib ? ` (BIB terakhir: ${res.lastBib})` : ""}.`);
        await render();
        await refreshPreview();
      } catch (e) {
        alert((e as Error).message);
      }
    }

    function exportCsv() {
      // Direct download via temporary anchor (the endpoint streams CSV).
      const url = bibsExportUrl(orgId, eventId);
      const token = sessionStorage.getItem("ivy_access_token");
      // Use fetch + blob to attach the Authorization header (the CSV endpoint requires it).
      fetch(url, { headers: { Authorization: `Bearer ${token}` } })
        .then(async (r) => {
          if (!r.ok) throw new Error(`HTTP ${r.status}`);
          const blob = await r.blob();
          const a = document.createElement("a");
          a.href = URL.createObjectURL(blob);
          a.download = "bibs.csv";
          a.click();
          URL.revokeObjectURL(a.href);
        })
        .catch((e) => alert((e as Error).message));
    }

    async function render() {
      try {
        const tickets = await loadTickets();
        const unassignedCount = tickets.filter((t) => !t.bibNumber).length;
        root.innerHTML = `
          <div class="space-y-4">
            <div class="flex flex-wrap items-center justify-between gap-3">
              <h1 class="text-xl font-bold">Tiket &amp; BIB</h1>
              <div class="flex flex-wrap gap-2">
                <button id="bulk-btn" class="rounded bg-blue-600 px-3 py-1.5 text-sm text-white hover:bg-blue-700">
                  Assign Semua (${unassignedCount})
                </button>
                <button id="export-btn" class="rounded border border-slate-300 bg-white px-3 py-1.5 text-sm text-slate-700 hover:bg-slate-50">
                  Export CSV
                </button>
              </div>
            </div>
            <p id="preview-next" class="text-sm text-slate-600"></p>

            ${tickets.length === 0 ? '<p class="text-slate-500">Belum ada tiket pada event ini.</p>' : `
              <div class="overflow-x-auto">
                <table class="w-full text-sm">
                  <thead>
                    <tr class="border-b border-slate-200 text-left text-xs uppercase text-slate-500">
                      <th class="py-2 pr-3">BIB</th>
                      <th class="py-2 pr-3">Tiket</th>
                      <th class="py-2 pr-3">Nama</th>
                      <th class="py-2 pr-3">Email</th>
                      <th class="py-2 pr-3">Kategori</th>
                      <th class="py-2 pr-3">Status</th>
                      <th class="py-2 pr-3">Aksi</th>
                    </tr>
                  </thead>
                  <tbody>
                    ${tickets.map((t) => `
                      <tr class="border-b border-slate-100" data-ticket-id="${esc(t.id)}">
                        <td class="py-2 pr-3 font-mono">
                          ${t.bibNumber ? `<span class="font-bold">${esc(t.bibNumber)}</span>${methodBadge(t.bibAssignmentMethod)}` : '<span class="text-slate-400">—</span>'}
                        </td>
                        <td class="py-2 pr-3 font-mono text-xs">${esc(t.ticketNumber)}</td>
                        <td class="py-2 pr-3">${esc(t.holderName)}</td>
                        <td class="py-2 pr-3 text-xs text-slate-600">${esc(t.holderEmail)}</td>
                        <td class="py-2 pr-3">${esc(t.categoryName)}</td>
                        <td class="py-2 pr-3">${statusBadge(t.status)}</td>
                        <td class="py-2 pr-3">
                          ${!t.bibNumber
                            ? `<button data-act="assign" class="rounded bg-green-600 px-2 py-1 text-xs text-white hover:bg-green-700">Assign</button>`
                            : `<button data-act="set" class="rounded border border-slate-300 bg-white px-2 py-1 text-xs hover:bg-slate-50">Ubah</button>
                               <button data-act="clear" class="ml-1 rounded border border-red-200 bg-white px-2 py-1 text-xs text-red-700 hover:bg-red-50">Hapus</button>`
                          }
                        </td>
                      </tr>
                    `).join("")}
                  </tbody>
                </table>
              </div>
            `}
          </div>
        `;

        document.getElementById("bulk-btn")?.addEventListener("click", handleBulkAssign);
        document.getElementById("export-btn")?.addEventListener("click", exportCsv);
        root.querySelectorAll<HTMLButtonElement>("[data-act]").forEach((btn) => {
          const row = btn.closest<HTMLTableRowElement>("tr[data-ticket-id]");
          if (!row) return;
          const id = row.dataset.ticketId!;
          const act = btn.dataset.act;
          btn.addEventListener("click", () => {
            if (act === "assign") void handleAutoAssign(id);
            else if (act === "set") void handleSet(id);
            else if (act === "clear") void handleClear(id);
          });
        });

        await refreshPreview();
      } catch (e) {
        root.innerHTML = `<p class="text-red-600">Gagal memuat tiket: ${esc((e as Error).message)}</p>`;
      }
    }

    await render();
  </script>
</OrganizerLayout>