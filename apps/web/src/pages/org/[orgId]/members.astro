---
export const prerender = false;
import OrganizerLayout from "../../../layouts/OrganizerLayout.astro";
const { orgId } = Astro.params;
---
<OrganizerLayout title="Anggota — ivyticketing">
  <div class="space-y-4">
    <h1 class="text-2xl font-bold text-slate-900">Anggota</h1>
    <div class="rounded-lg border border-slate-200 bg-white p-8 text-center">
      <p class="font-medium text-slate-700 mb-1">Segera tersedia</p>
      <p class="text-sm text-slate-500">Fitur manajemen anggota sedang dalam pengembangan.</p>
    </div>
    <p class="text-xs text-slate-400">
      <a href={`/org/${orgId}/dashboard`} class="underline hover:text-slate-600">Kembali ke Dashboard</a>
    </p>
  </div>
</OrganizerLayout>
