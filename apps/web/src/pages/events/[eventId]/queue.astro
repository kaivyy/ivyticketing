---
export const prerender = false;
import ParticipantLayout from "../../../layouts/ParticipantLayout.astro";
import WaitingRoom from "../../../components/queue/WaitingRoom.astro";
const { eventId } = Astro.params;
---
<ParticipantLayout title="Antrean Tiket">
  <div class="max-w-md mx-auto mt-12 px-4">
    <h1 class="text-xl font-bold mb-6 text-center">Ruang Tunggu</h1>
    {eventId
      ? <WaitingRoom eventId={eventId} />
      : <p class="text-center text-red-600">Event tidak ditemukan.</p>}
  </div>
</ParticipantLayout>
