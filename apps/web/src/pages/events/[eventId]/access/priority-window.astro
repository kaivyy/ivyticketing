---
export const prerender = false;
import ParticipantLayout from "../../../../layouts/ParticipantLayout.astro";
const { eventId } = Astro.params;
const categoryId = Astro.url.searchParams.get("categoryId") ?? "";
---
<ParticipantLayout title="Akses Prioritas">
  <div class="max-w-md mx-auto mt-12 px-4">
    <a href={`/events/${eventId}`} class="text-sm text-slate-500">← Kembali ke event</a>
    <h1 class="text-xl font-bold mt-4 mb-6 text-center">Akses Prioritas</h1>
    {eventId && categoryId
      ? (
        <div
          id="priority-root"
          data-event-id={eventId}
          data-category-id={categoryId}
          class="rounded-lg border border-slate-200 bg-white p-6 text-center"
        >
          <p class="text-slate-500">Memeriksa kelayakan…</p>
        </div>
      )
      : (
        <p class="text-center text-red-600">Parameter tidak lengkap.</p>
      )
    }
  </div>
</ParticipantLayout>

<script>
  import { authedFetch } from "../../../../lib/api";

  interface AccessGrantDTO {
    id: string;
    token: string;
    categoryId: string;
    expiresAt: string;
  }

  const root = document.getElementById("priority-root");
  if (!root) throw new Error("priority-root not found");

  const eventId    = root.dataset.eventId!;
  const categoryId = root.dataset.categoryId!;

  function showError(msg: string) {
    root!.innerHTML = `
      <p class="text-red-600 text-sm">${msg}</p>
      <a href="/events/${eventId}" class="mt-4 inline-block text-sm text-slate-600 underline">
        Kembali ke event
      </a>`;
  }

  async function run() {
    try {
      const grant = await authedFetch<AccessGrantDTO>(
        `/events/${eventId}/access/priority-window?categoryId=${categoryId}`
      );
      // Grant auto-issued — redirect to checkout with grant token
      const checkoutUrl =
        `/events/${eventId}/checkout?categoryId=${categoryId}&grantToken=${encodeURIComponent(grant.token)}`;
      root!.innerHTML = `
        <p class="text-green-700 font-semibold mb-3">Akses prioritas dikonfirmasi!</p>
        <p class="text-slate-600 text-sm mb-4">Kamu akan diarahkan ke halaman checkout…</p>
        <a href="${checkoutUrl}"
           class="inline-block rounded bg-green-700 px-6 py-2 text-white text-sm hover:bg-green-600">
          Lanjut Checkout
        </a>`;
      // Auto-redirect after short delay
      setTimeout(() => { window.location.href = checkoutUrl; }, 1500);
    } catch (e: unknown) {
      const msg = e instanceof Error ? e.message : "";
      if (msg.includes("PRIORITY_WINDOW_CLOSED") || msg.includes("WINDOW")) {
        showError("Jendela prioritas sudah ditutup.");
      } else if (msg.includes("NOT_ELIGIBLE") || msg.includes("ELIGIBLE")) {
        showError("Anda tidak memenuhi syarat untuk akses prioritas ini.");
      } else {
        showError(msg || "Gagal memeriksa akses prioritas.");
      }
    }
  }

  run();
</script>
