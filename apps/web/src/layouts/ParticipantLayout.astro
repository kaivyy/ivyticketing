---
import "../styles/global.css";
const { title = "ivyticketing" } = Astro.props;
const path = Astro.url.pathname;

function navClass(prefix: string): string {
  return path.startsWith(prefix)
    ? "font-medium text-slate-900"
    : "text-slate-500 hover:text-slate-900";
}
---
<!doctype html>
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-900">
    <header class="border-b border-slate-200 bg-white">
      <nav class="mx-auto flex max-w-3xl flex-wrap items-center justify-between gap-y-2 p-4">
        <a href="/participant/dashboard" class="font-semibold">ivyticketing</a>
        <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm">
          <a href="/events" class={navClass("/events")}>Jelajahi Event</a>
          <a href="/participant/orders" class={navClass("/participant/orders")}>Pesanan</a>
          <a href="/participant/tickets" class={navClass("/participant/tickets")}>Tiket</a>
          <button id="logout-btn" class="text-slate-500 hover:text-slate-900">Keluar</button>
        </div>
      </nav>
    </header>
    <main class="mx-auto max-w-3xl p-6"><slot /></main>

    <script>
      import { getToken, logout } from "../lib/auth";
      if (!getToken()) window.location.href = "/login";
      document.getElementById("logout-btn")?.addEventListener("click", async () => {
        await logout();
        window.location.href = "/login";
      });
    </script>
  </body>
</html>
