---
interface Props {
  eventId: string
  categoryId: string
  token: string
}
const { eventId, categoryId, token } = Astro.props
---

<div id="waitlist-status" class="border border-slate-200 rounded p-4">
  <p class="text-slate-500 text-sm">Memeriksa posisi waitlist…</p>
</div>

<script define:vars={{ eventId, categoryId, token }}>
  const API_URL = (typeof import !== "undefined" && import.meta?.env?.PUBLIC_API_URL) ?? "http://localhost:8080"

  async function loadPosition() {
    const el = document.getElementById("waitlist-status")
    if (!el) return
    try {
      const res = await fetch(
        `${API_URL}/api/v1/events/${eventId}/categories/${categoryId}/waitlist/my-position`,
        { headers: { Authorization: `Bearer ${token}` } }
      )
      if (!res.ok) {
        el.replaceChildren((() => {
          const p = document.createElement("p")
          p.className = "text-slate-500 text-sm"
          p.textContent = "Anda tidak memenuhi syarat untuk waitlist ini."
          return p
        })())
        return
      }
      const data = await res.json()

      if (data.status === "PROMOTED") {
        const wrap = document.createElement("div")
        const msg = document.createElement("p")
        msg.className = "text-green-700 font-semibold mb-2"
        msg.textContent = "Selamat! Anda dipromosikan ke posisi teratas. Silakan lanjutkan ke checkout."
        wrap.appendChild(msg)
        const link = document.createElement("a")
        link.href = `/events/${eventId}/checkout?categoryId=${categoryId}`
        link.className = "inline-flex items-center rounded-lg bg-slate-900 px-4 py-2 text-sm font-medium text-white hover:bg-slate-700"
        link.textContent = "Lanjut ke Checkout →"
        wrap.appendChild(link)
        el.replaceChildren(wrap)
      } else if (data.status === "EXPIRED") {
        const p = document.createElement("p")
        p.className = "text-red-600 text-sm"
        p.textContent = "Waktu pendaftaran Anda telah berakhir. Silakan coba lagi."
        el.replaceChildren(p)
      } else if (data.status === "NOT_ELIGIBLE") {
        const p = document.createElement("p")
        p.className = "text-slate-500 text-sm"
        p.textContent = "Anda tidak memenuhi syarat untuk waitlist ini."
        el.replaceChildren(p)
      } else {
        // handles WAITING and any other active status
        const wrap = document.createElement("div")
        const pos = document.createElement("p")
        pos.className = "text-slate-700"
        const label = document.createTextNode("Posisi antrean Anda: ")
        const strong = document.createElement("strong")
        strong.className = "text-slate-900"
        strong.textContent = `#${data.position}`
        pos.append(label, strong)
        const hint = document.createElement("p")
        hint.className = "text-slate-500 text-sm mt-1"
        hint.textContent = "Kami akan memberi tahu Anda saat giliran tiba."
        wrap.append(pos, hint)
        el.replaceChildren(wrap)
      }
    } catch {
      // silently ignore network errors — stale UI is acceptable
    }
  }

  loadPosition()
  // Segarkan posisi setiap 60 detik
  setInterval(loadPosition, 60_000)
</script>
