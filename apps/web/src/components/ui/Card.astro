---
interface Props {
  class?: string;
  padding?: "sm" | "md" | "lg";
}

const { class: extraClass, padding = "md" } = Astro.props;

const paddingClass: Record<string, string> = {
  sm: "p-4",
  md: "p-6",
  lg: "p-8",
};

const classes = [
  "bg-white rounded-2xl border border-slate-200 shadow-sm",
  paddingClass[padding],
  extraClass,
]
  .filter(Boolean)
  .join(" ");
---

<div class={classes}><slot /></div>
