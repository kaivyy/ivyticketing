---
export const prerender = false;
const { eventId, categoryId, drawId } = Astro.props;
---
<div
  id="ballot-status"
  data-event-id={eventId}
  data-category-id={categoryId}
  data-draw-id={drawId ?? ""}
  class="rounded-lg border border-slate-200 bg-white p-6"
>
  <p class="text-slate-500 text-center">Memuat status ballot…</p>
</div>

<script>
  import { getMyBallotEntry, applyBallot, withdrawBallot } from "../../lib/ballot";

  const root = document.getElementById("ballot-status")!;
  const eventId = root.dataset.eventId!;
  const categoryId = root.dataset.categoryId!;
  const drawId = root.dataset.drawId ?? "";

  type BallotEntry = Awaited<ReturnType<typeof getMyBallotEntry>>;

  // Live countdown ticker — returns a cleanup function
  function startCountdown(
    isoDeadline: string,
    onTick: (label: string) => void,
    onExpired: () => void
  ): ReturnType<typeof setInterval> {
    const tick = () => {
      const diff = new Date(isoDeadline).getTime() - Date.now();
      if (diff <= 0) {
        onExpired();
        clearInterval(timer);
        return;
      }
      const h = Math.floor(diff / 3_600_000);
      const m = Math.floor((diff % 3_600_000) / 60_000);
      const s = Math.floor((diff % 60_000) / 1_000);
      onTick(`${h}j ${m}m ${s}d tersisa`);
    };
    tick();
    const timer = setInterval(tick, 1_000);
    return timer;
  }

  let countdownTimer: ReturnType<typeof setInterval> | undefined;

  function render(entry: BallotEntry) {
    if (countdownTimer !== undefined) {
      clearInterval(countdownTimer);
      countdownTimer = undefined;
    }

    if (!entry) {
      root.innerHTML = drawId
        ? `<div class="text-center">
            <p class="text-slate-500 text-sm mb-4">Kamu belum mendaftar ballot ini.</p>
            <button id="btn-apply"
              class="rounded bg-slate-900 px-4 py-2 text-white text-sm hover:bg-slate-700">
              Daftar Ballot
            </button>
          </div>`
        : `<p class="text-slate-500 text-center text-sm">Ballot belum tersedia.</p>`;

      document.getElementById("btn-apply")?.addEventListener("click", async () => {
        try {
          await applyBallot(eventId, categoryId, drawId);
          await refresh();
        } catch (e: unknown) {
          const errMsg = document.createElement("p");
          errMsg.className = "text-red-600 text-sm mt-2";
          errMsg.textContent = (e as Error).message;
          document.getElementById("btn-apply")?.insertAdjacentElement("afterend", errMsg);
        }
      });
      return;
    }

    const statusLabel: Record<string, string> = {
      APPLIED:      "Terdaftar — menunggu pengundian",
      WINNER:       "Menang!",
      WAITLISTED:   "Waitlist",
      NOT_SELECTED: "Tidak terpilih",
      CONVERTED:    "Pesanan dibuat",
      WITHDRAWN:    "Ditarik",
    };

    const badge = (status: string) =>
      `<span class="inline-block rounded-full px-3 py-1 text-xs font-medium ${
        status === "WINNER"       ? "bg-green-100 text-green-700" :
        status === "WAITLISTED"   ? "bg-amber-100 text-amber-700" :
        status === "NOT_SELECTED" ? "bg-red-100 text-red-600" :
        "bg-slate-100 text-slate-600"
      }">${statusLabel[status] ?? status}</span>`;

    let extra = "";
    if (entry.status === "WINNER" && entry.payment_deadline) {
      const deadlinePassed = new Date(entry.payment_deadline).getTime() <= Date.now();
      if (deadlinePassed) {
        extra = `
          <p class="text-red-600 text-sm mt-2">Batas waktu pembayaran telah lewat.</p>`;
      } else {
        const checkoutUrl = `/events/${eventId}/checkout?categoryId=${categoryId}&grantToken=${entry.access_grant_id}`;
        extra = `
          <p class="text-sm text-amber-700 mt-2">
            Batas waktu: <span id="ballot-countdown" class="font-medium"></span>
          </p>
          <a id="btn-checkout"
            href="${checkoutUrl}"
            class="mt-3 inline-block rounded bg-green-700 px-4 py-2 text-white text-sm hover:bg-green-600">
            Lanjut Checkout
          </a>`;
      }
    }
    if (entry.status === "WAITLISTED" && entry.waitlist_rank != null) {
      extra = `<p class="text-sm text-slate-500 mt-2">Posisi waitlist: #${entry.waitlist_rank}</p>`;
    }
    if (entry.status === "APPLIED") {
      extra = `
        <button id="btn-withdraw" class="mt-3 text-xs text-red-500 underline">
          Tarik pendaftaran
        </button>`;
    }

    root.innerHTML = `<div class="text-center">${badge(entry.status)}${extra}</div>`;

    // Start live countdown for WINNER with active deadline
    if (
      entry.status === "WINNER" &&
      entry.payment_deadline &&
      new Date(entry.payment_deadline).getTime() > Date.now()
    ) {
      const countdownEl = document.getElementById("ballot-countdown");
      const checkoutBtn = document.getElementById("btn-checkout") as HTMLAnchorElement | null;
      countdownTimer = startCountdown(
        entry.payment_deadline,
        (label) => {
          if (countdownEl) countdownEl.textContent = label;
        },
        () => {
          // Deadline passed: disable CTA, show expired message
          if (checkoutBtn) {
            checkoutBtn.removeAttribute("href");
            checkoutBtn.className = "mt-3 inline-block rounded bg-slate-300 px-4 py-2 text-slate-500 text-sm cursor-not-allowed";
            checkoutBtn.textContent = "Waktu habis";
          }
          if (countdownEl) {
            countdownEl.textContent = "Waktu habis";
            countdownEl.className = "font-medium text-red-600";
          }
          const parent = countdownEl?.closest(".text-center");
          if (parent) {
            const msg = document.createElement("p");
            msg.className = "text-red-600 text-sm mt-2";
            msg.textContent = "Batas waktu pembayaran telah lewat.";
            parent.appendChild(msg);
          }
        }
      );
    }

    document.getElementById("btn-withdraw")?.addEventListener("click", async () => {
      if (!confirm("Tarik pendaftaran ballot ini?")) return;
      try {
        await withdrawBallot(eventId, categoryId);
        await refresh();
      } catch (e: unknown) {
        alert((e as Error).message);
      }
    });
  }

  async function refresh() {
    try {
      render(await getMyBallotEntry(eventId, categoryId));
    } catch {
      root.innerHTML = `<p class="text-xs text-red-500 text-center">Gagal memuat status ballot.</p>`;
    }
  }

  refresh();
  setInterval(refresh, 30_000);
  document.addEventListener("visibilitychange", () => {
    if (!document.hidden) refresh();
  });
</script>
